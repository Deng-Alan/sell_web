{
  "name": "sell-web",
  "version": "1.0.0",
  "private": true,
  "description": "商品展示网站 - 基础版 MVP",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "lint:frontend": "npm run lint --workspace=frontend",
    "typecheck:frontend": "npm run typecheck --workspace=frontend",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run",
    "build:backend": "mvn -f backend/pom.xml -DskipTests package"
  }
}
